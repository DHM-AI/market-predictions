ANTHROPIC_API_KEY=your_anthropic_api_key_here
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# ── Slack alerts (replaces Gmail) ─────────────────────────────────────────────
# Setup: https://api.slack.com/apps → Create App → Incoming Webhooks → Add to Workspace
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Legacy Gmail (optional fallback — not required if Slack is set) ───────────
# GMAIL_USER=your_gmail_address@gmail.com
# GMAIL_APP_PASS=your_gmail_app_password_here
# ALERT_EMAIL=renato@deltahubmedia.com

# ── Database ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── Alpaca Trading ────────────────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_MODE=false
BANKROLL=50000
